# JobKit environment template. Copy to .env and fill in values.

# App
APP_ENV=prod
APP_URL=https://jobkit.app # or your own domain

DEMO_USER_EMAIL=demo1@jobkit.app
DEMO_USER_PASSWORD=12345
DEMO_USER_ID=

# Supabase (required for auth and database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret

# Frontend (Vite): same project — used for Supabase Auth in the browser
# Copy .env to frontend/.env or prefix with VITE_ in repo root and expose to build
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key

# Legacy auth (kept for backward compat, will be removed)
SESSION_SECRET=change_me_long_random
ADMIN_USERNAME=chris
ADMIN_PASSWORD=change_me_strong
# Admin: grant a Supabase user access to Admin (invite codes). Use the user's UUID from auth.users.id.
# You cannot edit auth.users in the Supabase dashboard (auth schema is read-only). Set this env var instead.
# Example: ADMIN_USER_ID=903dc38c-ec0b-4967-bf87-cab3bfc7be74
# ADMIN_USER_ID=

# Database: when set, use Supabase Postgres; otherwise SQLite at JOBKIT_DATA_DIR/jobkit.db
# Direct (port 5432) is IPv6-only; if you see "Network is unreachable", use the pooler (port 6543) instead.
# Option A - single URL (password with @#% must be percent-encoded, e.g. @ -> %40):
#   Direct:   postgresql://postgres:[PASSWORD]@db.[project-ref].supabase.co:5432/postgres
#   Pooler:   postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
#   Canada Central uses aws-1-ca-central-1.pooler.supabase.com (not aws-0).
# Option B - separate vars (password can contain @ safely):
# DATABASE_HOST=db.[project-ref].supabase.co
# DATABASE_USER=postgres
# DATABASE_PASSWORD=
# DATABASE_PORT=5432
# DATABASE_NAME=postgres

# Storage paths (defaults work inside Docker)
JOBKIT_DATA_DIR=/app/data
JOBKIT_JOBS_DIR=/app/jobs
JOBKIT_OUTPUTS_DIR=/app/outputs

# LLM provider (OpenRouter)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
LLM_MODEL=anthropic/claude-sonnet-4.6
LLM_TEMPERATURE=0.2

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://jobs.chrislawrence.ca/api/google/oauth/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=change_me_32bytes_base64

# Optional: map JobKit fields to your sheet column headers (leave empty to use default column order)
GOOGLE_SHEETS_COLUMN_COMPANY=Company Name
GOOGLE_SHEETS_COLUMN_ROLE=Role
GOOGLE_SHEETS_COLUMN_STATUS=Application Status
GOOGLE_SHEETS_COLUMN_JOB_URL=Job URL
GOOGLE_SHEETS_COLUMN_DATE_SUBMITTED=Date Submitted
GOOGLE_SHEETS_COLUMN_RESUME_LINK=Resume Used
GOOGLE_SHEETS_COLUMN_COVER_LINK=Cover Used
GOOGLE_SHEETS_COLUMN_NOTES_LINK=Notes