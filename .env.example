# JobKit environment template. Copy to .env and fill in values.

# App
APP_ENV=prod
APP_URL=https://jobs.chrislawrence.ca
SESSION_SECRET=change_me_long_random
ADMIN_USERNAME=chris
ADMIN_PASSWORD=change_me_strong

# Storage paths (defaults work inside Docker)
JOBKIT_DATA_DIR=/app/data
JOBKIT_JOBS_DIR=/app/jobs
JOBKIT_OUTPUTS_DIR=/app/outputs

# LLM provider (OpenAI-compatible)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.2

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://jobs.chrislawrence.ca/api/google/oauth/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=change_me_32bytes_base64

# Drive/Sheets
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_TAB_NAME=Job Applications
GOOGLE_SHEETS_URL_COLUMN=Job URL


# Optional: map JobKit fields to your sheet column headers (leave empty to use default column order)
# GOOGLE_SHEETS_COLUMN_COMPANY=Company Name
# GOOGLE_SHEETS_COLUMN_ROLE=Role
# GOOGLE_SHEETS_COLUMN_STATUS=Application Status
# GOOGLE_SHEETS_COLUMN_JOB_URL=Job URL
# GOOGLE_SHEETS_COLUMN_DATE_SUBMITTED=Date Submitted
# GOOGLE_SHEETS_COLUMN_RESUME_LINK=Resume Used
# GOOGLE_SHEETS_COLUMN_COVER_LINK=Cover Used
# GOOGLE_SHEETS_COLUMN_NOTES_LINK=Notes